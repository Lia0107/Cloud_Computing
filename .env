# Database Configuration
DB_HOST=your-db-rds
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=postgres
DB_PASSWORD=your-db-pwd
DB_SSL=true

# JWT Secret
JWT_SECRET=your-jwt-secret-key

# Frontend URL - Use ALB DNS name
FRONTEND_URL=your-url

# Backend API URL
REACT_APP_API_URL=your-api-url

# AWS Configuration
AWS_ACCESS_KEY_ID=your-session-id
AWS_SECRET_ACCESS_KEY=your-session-key
AWS_SESSION_TOKEN=your-session-token
AWS_REGION=your-region
S3_BUCKET_NAME=your-s3-bucket

# Node Environment
NODE_ENV=production

# Admin Configuration
ADMIN_SIGNUP_CODE=admin-code
